{
  "name": "vercel-api",
  "version": "0.0.0-development",
  "description": "",
  "license": "MIT",
  "packageManager": "pnpm@7.22.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": {
    "name": "thilllon",
    "email": "thilllon970@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thilllon/vercel-api.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "jest",
    "format": "prettier --write --list-different .",
    "lint": "eslint --fix .",
    "prepare": "husky install && chmod +x .husky/*",
    "dev": "tsx src/index.ts",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "release": "pnpm format && pnpm lint && pnpm build && release-it"
  },
  "prettier": {
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100
  },
  "lint-staged": {
    "*.{css,less,scss,html,json,jsx,js,ts,tsx,md,mdx,yaml,yml,tml,toml,xml}": [
      "prettier -w -l"
    ],
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "**/src/**/*": [
      "prettier -w -l",
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}"
    },
    "github": {
      "release": "true"
    }
  },
  "dependencies": {
    "axios": "^1.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^16.3.0",
    "@commitlint/config-conventional": "^16.2.4",
    "@commitlint/cz-commitlint": "^17.4.0",
    "@types/dotenv": "^8.2.0",
    "@types/jest": "^29.2.5",
    "@types/node": "^18.11.18",
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "cheerio": "1.0.0-rc.12",
    "commitizen": "^4.2.6",
    "commitlint": "^17.4.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^16.0.3",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "git-cz": "^4.9.0",
    "husky": "^8.0.3",
    "inquirer": "^8.2.5",
    "jest": "^29.3.1",
    "lint-staged": "^12.5.0",
    "prettier": "^2.8.2",
    "release-it": "^15.6.0",
    "ts-node-dev": "^2.0.0",
    "tsup": "^6.5.0",
    "tsx": "^3.12.1",
    "typescript": "^4.9.4"
  },
  "peerDependencies": {
    "inquirer": "^8.0.0"
  }
}
